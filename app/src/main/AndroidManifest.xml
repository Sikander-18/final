<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Existing permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Storage permissions -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <!-- New permissions for QR code and app blocking -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Additional permissions for better app blocking -->
    <uses-permission android:name="android.permission.GET_TASKS" />
    <uses-permission android:name="android.permission.REORDER_TASKS" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />

    <!-- New permission for PACKAGE_USAGE_STATS -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />
    
    <!-- Permission for scheduling exact alarms (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    
    <!-- Permission for boot completed to start services automatically -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- Permission to request battery optimization exemption -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- Permission for alarm manager -->
    <uses-permission android:name="android.permission.SET_ALARM" />

    <!-- Permission for voice assistant speech-to-text -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    


    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Master2"
        tools:targetApi="31">

        <!-- Existing activities -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Master2.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginTypeActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <!-- ParentLoginActivity REMOVED (Dead Code) -->

        <activity
            android:name=".ParentAuthActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ParentEmailLoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ParentSignupActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".OtpVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ParentDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />
            
        <activity
            android:name=".GuideBookActivity"
            android:exported="false"
            android:label="Guide Book"
            android:theme="@style/Theme.Master2.NoActionBar" />
            
        <activity
            android:name=".ParentSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".InfoDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ChildNotificationsActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".TimerStatusActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <service
            android:name=".services.PermissionMonitorService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".services.PermissionEventListener"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".services.PackageChangeService"
            android:enabled="true"
            android:exported="false" />

        <activity
            android:name=".LoadingActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ChildLoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ChildNameActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ChildPermissionsActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <!-- DeviceIDCheckActivity REMOVED (Dead Code) -->

        <activity
            android:name=".RoleSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <!-- New activities for QR code and preset functionality -->
        <activity
            android:name=".PresetCreationActivity"
            android:exported="false"
            android:label="Create Focus Mode Preset"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".QRDisplayActivity"
            android:exported="false"
            android:label="QR Code"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".QRScannerActivity"
            android:exported="false"
            android:label="Scan QR Code"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ChildInstalledAppsActivity"
            android:exported="false"
            android:label="Installed Apps"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ChildDashboardActivity"
            android:exported="false"
            android:label="Child Dashboard"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ChildUsageActivity"
            android:exported="false"
            android:label="Child Usage"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <!-- SUSAGE-style Usage Activities -->
        <activity
            android:name=".ChildDeviceUsageActivity"
            android:exported="false"
            android:label="Usage Data"
            android:parentActivityName=".ChildDashboardActivity"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ChildUsageViewActivity"
            android:exported="false"
            android:label="Child Usage"
            android:parentActivityName=".ParentDashboardActivity"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".TermsAndServicesActivity"
            android:exported="false"
            android:label="Terms and Services"
            android:theme="@style/Theme.Master2.NoActionBar" />


        <activity
            android:name=".AddTaskActivity"
            android:exported="false"
            android:label="Add Task"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".AppSelectionActivity"
            android:exported="false"
            android:label="Select Apps"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".AddTaskActivity"
            android:exported="false"

            android:label="Add Task"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".ChildAppListActivity"
            android:exported="false"
            android:label="Child Apps"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".DailyLimitsActivity"
            android:exported="false"
            android:label="Daily Usage Limits"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".TimerManagementActivity"
            android:exported="false"
            android:label="Timer Management"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <activity
            android:name=".voice.VoiceAssistantActivity"
            android:exported="false"
            android:label="Voice Assistant"
            android:theme="@style/Theme.Master2.NoActionBar" />

        <!-- App Blocking Activity -->
        <activity
            android:name=".AppBlockActivity"
            android:exported="false"
            android:label="Time's Up"
            android:theme="@style/Theme.Master2.NoActionBar"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true" />

        <!-- Accessibility Service for App Blocking -->
        <service
            android:name=".BlockService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false"
            android:enabled="true"
            tools:ignore="RestrictedApi">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Remote Block Monitoring Service -->
        <service
            android:name=".RemoteBlockService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="dataSync" />

        <!-- Live Timer Service -->
        <service
            android:name=".LiveTimerService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="dataSync" />

        <!-- Smart Timer Service -->
        <service
            android:name=".SmartTimerService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="dataSync" />

        <!-- Daily Usage Limit Service -->
        <service
            android:name=".DailyUsageLimitService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="dataSync" />

        <!-- Per-App Timer Service -->
        <service
            android:name=".services.AppTimerService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="dataSync" />


        <!-- Daily Timer Reset Service -->



        <service
            android:name=".DailyTimerResetService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="dataSync" />

        <!-- Usage Limiter Reset Service -->
        <service
            android:name=".UsageLimiterResetService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="dataSync" />

        <!-- Real-time Data Sync Service -->
        <service
            android:name=".services.RealTimeDataSyncService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="dataSync" />

        <!-- Persistent Connection Service for Child Devices -->
        <service
            android:name=".services.PersistentConnectionService"
            android:exported="false"
            android:enabled="true" />
        
        <!-- Enhanced Usage Limiter Service -->
        <service
            android:name=".EnhancedUsageLimiterService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="dataSync" />

        <!-- Permanent Expired Timer Notification Service -->
        <service
            android:name=".PermanentExpiredNotificationService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="persistent_timer_notification" />
        </service>

        <!-- Usage Data Storage Service -->
        <service
            android:name=".UsageDataStorageService"
            android:exported="false"
            android:enabled="true" />

        <!-- Persistent Timer Notification Service for Parent Devices -->
        <service
            android:name=".PersistentTimerNotificationService"
            android:exported="false"
            android:enabled="true"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="persistent_timer_reset_notification" />
        </service>

        <!-- Boot Receiver for automatic service start -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- 🛡️ BULLETPROOF: Service Watchdog for auto-restart -->
        <receiver
            android:name=".ServiceWatchdog"
            android:exported="true"
            android:enabled="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="com.example.master2.CHECK_SERVICES" />
                <action android:name="com.example.master2.RESTART_SERVICES" />
            </intent-filter>
        </receiver>
        
        <!-- 🛡️ DEVICE ADMIN: Uninstall Protection -->
        <receiver
            android:name=".AppDeviceAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <action android:name="android.app.action.DEVICE_ADMIN_DISABLED" />
                <action android:name="android.app.action.DEVICE_ADMIN_DISABLE_REQUESTED" />
            </intent-filter>
        </receiver>

        <!-- 📦 APP STATUS TRACKER: Monitor installations/uninstallations -->
        <receiver
            android:name=".AppInstallUninstallReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".voice.VoiceAssistantAlarmReceiver"
            android:enabled="true"
            android:exported="false" />




    </application>

</manifest>