<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAssistant"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Voice Assistant"
        app:titleTextColor="#333333" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@+id/hsvChips"
        app:layout_constraintTop_toBottomOf="@id/toolbarAssistant" />

    <HorizontalScrollView
        android:id="@+id/hsvChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/layoutInput">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipBlockInstagram"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/rounded_input_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Block Instagram"
                android:textColor="#6200EE"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipBlockYoutube"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/rounded_input_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Block YouTube"
                android:textColor="#6200EE"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipNightBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_input_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="Night Block WhatsApp"
                android:textColor="#6200EE"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/etCommand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/rounded_input_bg"
            android:gravity="center_vertical|start"
            android:hint="e.g. block instagram from 10 pm to 2 am"
            android:inputType="text"
            android:minHeight="48dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp" />

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voice Input"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="#6200EE" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Send Command"
            android:src="@android:drawable/ic_menu_send"
            android:visibility="gone"
            app:tint="#6200EE" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
