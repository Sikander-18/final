<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_dashboard_gradient"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_sentinel_foreground" />


        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permissions Required"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To keep you safe, we need a few permissions."
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:fontFamily="sans-serif" />

        <!-- Accessibility Service Card -->
        <LinearLayout
            android:id="@+id/accessibilitySection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_outline_blue"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"> <!-- Changed to top alignment for multi-line text -->

                <ImageView
                    android:id="@+id/accessibilityIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_settings"
                    app:tint="#DC2626" /> <!-- Default Red -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accessibility Service"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/accessibilityStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Required for safety features"
                        android:textSize="13sp"
                        android:textColor="#DC2626"
                        android:layout_marginTop="4dp"
                        android:lineSpacingMultiplier="1.2" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnAccessibility"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="Grant Permission"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_primary_pill"
                app:backgroundTint="@null"
                android:elevation="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Usage Access Card -->
        <LinearLayout
            android:id="@+id/usageAccessSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_outline_blue"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <ImageView
                    android:id="@+id/usageAccessIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_usage" 
                    app:tint="#DC2626" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Usage Access"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/usageAccessStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Required to monitor app usage"
                        android:textSize="13sp"
                        android:textColor="#DC2626"
                        android:layout_marginTop="4dp"
                        android:lineSpacingMultiplier="1.2" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnUsageAccess"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="Grant Permission"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_primary_pill"
                app:backgroundTint="@null"
                android:elevation="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Notification Access Card -->
        <LinearLayout
            android:id="@+id/notificationSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_outline_blue"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <ImageView
                    android:id="@+id/notificationIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_shield"
                    app:tint="#DC2626" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifications"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/notificationStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Required for important alerts"
                        android:textSize="13sp"
                        android:textColor="#DC2626"
                        android:layout_marginTop="4dp"
                        android:lineSpacingMultiplier="1.2" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnNotification"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="Grant Permission"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_primary_pill"
                app:backgroundTint="@null"
                android:elevation="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Battery Optimization Card -->
        <LinearLayout
            android:id="@+id/batteryOptimizationSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_outline_blue"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <ImageView
                    android:id="@+id/batteryOptimizationIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_time"
                    app:tint="#DC2626" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Battery Optimization"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/batteryOptimizationStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Allow to keep app running"
                        android:textSize="13sp"
                        android:textColor="#DC2626"
                        android:layout_marginTop="4dp"
                        android:lineSpacingMultiplier="1.2" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnBatteryOptimization"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="Grant Permission"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_primary_pill"
                app:backgroundTint="@null"
                android:elevation="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- 🛡️ Device Admin Card (Uninstall Protection) - OPTIONAL -->
        <LinearLayout
            android:id="@+id/deviceAdminSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_outline_blue"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <!-- Optional Badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPTIONAL"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#F59E0B"
                android:background="@drawable/bg_badge_warning"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <ImageView
                    android:id="@+id/deviceAdminIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_shield"
                    app:tint="#DC2626" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uninstall Protection"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/deviceAdminStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prevents app removal"
                        android:textSize="13sp"
                        android:textColor="#DC2626"
                        android:layout_marginTop="4dp"
                        android:lineSpacingMultiplier="1.2" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnDeviceAdmin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="Enable Protection"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_primary_pill"
                app:backgroundTint="@null"
                android:elevation="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Proceed Button -->
        <Button
            android:id="@+id/btnProceed"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Grant Permissions First"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_primary_pill"
            app:backgroundTint="@null"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:layout_marginBottom="32dp" />

    </LinearLayout>

</ScrollView>