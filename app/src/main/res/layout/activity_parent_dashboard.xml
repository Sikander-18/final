<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_gradient_mesh">

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="24dp"
        app:itemIconTint="@color/selector_bottom_nav"
        app:itemTextColor="@color/selector_bottom_nav"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/parent_bottom_nav_menu" />

    <!--  Home Content  -->
    <ScrollView
        android:id="@+id/homeContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- 1. Header Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="24dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="Welcome Back"
                        android:textColor="@color/neutral_600"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvParentName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Parent"
                        android:textColor="@color/neutral_900"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif"
                        android:text="Today"
                        android:textColor="@color/neutral_500"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Notification Bell Icon (Glass Style) -->
                <FrameLayout
                    android:id="@+id/btnNotifications"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_glass_round"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/neutral_800" />

                    <!-- Notification Badge -->
                    <TextView
                        android:id="@+id/tvNotificationBadge"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_badge_red"
                        android:gravity="center"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone"
                        tools:text="3"
                        tools:visibility="visible" />
                </FrameLayout>
            </LinearLayout>

            <!-- 2. Device Selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">
                
                <!-- Info Banner -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_white_rounded"
                    android:backgroundTint="#E8F5E9"
                    android:padding="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Timer set on apps won't block apps after timer has expired. Blocking is to be done manually."
                        android:textColor="#1B5E20"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:lineSpacingExtra="3dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginBottom="16dp"
                    android:text="Your Family"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/neutral_800"
                    android:textSize="18sp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="24dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/llDeviceList"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Chips inflated programmatically -->
                        
                        <!-- "Add Device" Chip -->
                         <LinearLayout
                            android:id="@+id/btnAddDevice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_white_rounded"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:gravity="center"
                            android:layout_marginStart="4dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_add"
                                app:tint="@color/primary_600"/>
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="14sp"
                                android:layout_marginStart="6dp"
                                android:textColor="@color/primary_600"/>
                        </LinearLayout>

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 3. Status/Activity Card (Premium Glass) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:text="Activity Overview"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/neutral_800"
                android:textSize="18sp" />

            <!-- Using a FrameLayout to contain the card for shadows if needed in future -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_glass"
                    android:padding="24dp">
    
                    <!-- Device Status Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="24dp">
                        
                        <ImageView
                             android:id="@+id/ivDeviceIcon"
                             android:layout_width="16dp"
                             android:layout_height="16dp"
                             android:src="@drawable/ic_device"
                             app:tint="@color/neutral_400"
                             android:layout_marginEnd="8dp"/>
                        <TextView
                            android:id="@+id/tvDeviceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="Select a child"
                            android:textColor="@color/neutral_500"
                            android:textSize="14sp" />
    

                    </LinearLayout>
                    
                    <!-- Usage Metrics -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <!-- Usage Icon -->
                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_circle_primary_soft">
                             <ImageView
                                 android:layout_width="28dp"
                                 android:layout_height="28dp"
                                 android:layout_gravity="center"
                                 android:src="@drawable/ic_chart_premium"
                                 app:tint="@color/primary_600"/>
                        </FrameLayout>
    
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:orientation="vertical">
    
                             <TextView
                                 android:id="@+id/tvUsageSummaryTitle"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Total Screen Time"
                                 android:fontFamily="sans-serif"
                                 android:textSize="14sp"
                                 android:textColor="@color/neutral_500"/>
                             
                             <TextView
                                 android:id="@+id/tvTotalTime"
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="0h 0m"
                                 android:fontFamily="sans-serif-medium"
                                 android:textSize="32sp"
                                 android:textColor="@color/neutral_900"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- ⚠️ UNINSTALL WARNING BANNER (Hidden by default) -->
            <LinearLayout
                android:id="@+id/layoutUninstallWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_error_rounded"
                android:padding="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_warning"
                        app:tint="@android:color/white"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:id="@+id/tvUninstallWarningTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ App Uninstalled"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvUninstallWarningMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="App has been uninstalled from the child's device.\nPlease reinstall on the child's device and reconnect."
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp"/>

                <TextView
                    android:id="@+id/tvUninstallLastSeen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Last seen: Never"
                    android:textColor="#FFFFFFBB"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- 5. Quick Actions Grid -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="Quick Actions"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/neutral_800"
                android:textSize="18sp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:paddingHorizontal="16dp"
                android:useDefaultMargins="true">

                <!-- 1. Usage Stats -->
                <LinearLayout
                    android:id="@+id/cardUsageStatsAction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_card_glass"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="20dp"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_circle_primary_soft"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chart_premium"
                            app:tint="@color/primary_600"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detailed Stats"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:textColor="@color/neutral_900"/>
                </LinearLayout>

                <!-- 2. App Limits -->
                 <LinearLayout
                    android:id="@+id/cardAppLimitsAction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_card_glass"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="20dp"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                     <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_circle_error_soft"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield_time"
                            app:tint="@color/error_600"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="App Limits"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:textColor="@color/neutral_900"/>
                </LinearLayout>

            </GridLayout>

            <!-- Hidden placeholders required for compilation -->
            <Button android:id="@+id/btnRemoveDevice" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
            <Button android:id="@+id/btnUpdateUsageData" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
            <ImageView android:id="@+id/btnPreviousDate" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
            <ImageView android:id="@+id/btnNextDate" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
            <Switch android:id="@+id/switchFocusMode" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
            <TextView android:id="@+id/tvFocusModeStatus" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
            <Button android:id="@+id/btnEditAppList" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
            <Button android:id="@+id/btnShowQRFullscreen" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
            <TextView android:id="@+id/tvSelectedDate" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>
            <Button android:id="@+id/btnViewInstalledApps" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp"/>

        </LinearLayout>
    </ScrollView>
    <!-- Floating Guide Button -->
    <LinearLayout
        android:id="@+id/btnGuideBook"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="90dp"
        android:layout_marginEnd="24dp"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your own\npersonal guide"
            android:textSize="12sp"
            android:textColor="@color/neutral_600"
            android:background="@drawable/bg_white_rounded"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:gravity="center"
            android:layout_marginEnd="8dp"
            android:elevation="4dp"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_help_premium"
            app:tint="@android:color/white"
            app:backgroundTint="#2979FF"
            app:elevation="6dp"
            app:fabSize="normal"/>
            
            <!-- Note: Using ic_warning temporarily as a placeholder if generic help icon isn't available. 
                 Will look for a book/help icon in available drawables or use system default -->

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
