<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_mesh"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connect New Device"
            android:fontFamily="sans-serif-medium"
            android:textSize="24sp"
            android:textColor="@color/neutral_900" />

        <ImageButton
            android:id="@+id/btnCloseNew"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_close_circle_premium"
            android:background="@drawable/bg_circle_button"
            android:padding="12dp"
            android:contentDescription="Close"
            android:scaleType="fitCenter"
            app:tint="@color/neutral_700"/>
    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan this QR code from your child's device\nto establish a secure connection."
                android:textAlignment="center"
                android:textColor="@color/neutral_600"
                android:textSize="16sp"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="16dp"/>

            <!-- Glass Card for QR -->
            <FrameLayout
                android:id="@+id/llQRSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_glass"
                android:padding="20dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivQRCode"
                        android:layout_width="260dp"
                        android:layout_height="260dp"
                        android:background="@android:color/white"
                        android:padding="16dp" 
                        android:elevation="4dp"/>

                    <!-- Timer Bar -->
                    <ProgressBar
                        android:id="@+id/progressTimer"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="160dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="16dp"
                        android:progressTint="@color/primary_600" 
                        android:progressBackgroundTint="#E0E7FF"/>

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="02:00"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="14sp"
                        android:textColor="@color/neutral_500"
                        android:layout_marginTop="4dp"/>
                        


                </LinearLayout>
            </FrameLayout>

            <Button
                android:id="@+id/btnRefreshQR"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Generate New Code"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/primary_600"
                android:layout_marginTop="16dp"/>

            <!-- Security Note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:padding="16dp"
                android:background="@drawable/bg_card_glass">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_shield_time"
                        app:tint="@color/neutral_500"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Security Information"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/neutral_700"
                        android:textSize="14sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="QR codes automatically expire every 2 minutes for your security. Only share this code with devices you intend to safeguard."
                    android:textSize="13sp"
                    android:textColor="@color/neutral_500"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <!-- Hidden View for Compatibility -->
            <LinearLayout
                android:id="@+id/llConnectedDevices"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone">
                <TextView android:id="@+id/tvConnectedCount" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>