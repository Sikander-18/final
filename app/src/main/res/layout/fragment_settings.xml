<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_50"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Main Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp">

                <!-- App Icon and Welcome -->
                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_launcher_foreground"
                    android:layout_gravity="center"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👋 Hey there!"
                    android:textColor="@color/primary_600"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome to Monarch - Your Digital Helper! 🌟"
                    android:textColor="@color/neutral_800"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Why This App Helps You Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎯 Why This App Helps You"
                    android:textColor="@color/primary_600"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 Helps you use your device in a healthy way\n\n⏰ Teaches you good time management skills\n\n🎮 Makes sure you have time for homework, play, and sleep\n\n👨‍👩‍👧‍👦 Keeps your family connected and caring for each other\n\n🌱 Helps you grow into a responsible digital citizen"
                    android:textColor="@color/neutral_700"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- How It Works Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔧 How It Works"
                    android:textColor="@color/primary_600"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🤝 Your parents can set helpful limits on apps and screen time\n\n📊 You can see how much time you spend on different activities\n\n⚡ The app works quietly in the background without interrupting you\n\n🔒 Your privacy is protected - only your parents see your data\n\n✨ Everything happens automatically so you can focus on having fun!"
                    android:textColor="@color/neutral_700"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Benefits Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💪 How This Saves You"
                    android:textColor="@color/primary_600"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="😴 Better sleep because you won't use devices too late\n\n📚 More time for homework and learning new things\n\n🏃‍♂️ More time to play outside and be active\n\n👥 Better friendships because you'll spend time with friends in person\n\n🧠 Stronger focus and concentration in school\n\n❤️ Closer family relationships with more quality time together"
                    android:textColor="@color/neutral_700"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Remember Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/primary_50"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💝 Remember"
                    android:textColor="@color/primary_600"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your parents care about you and want to help you develop healthy habits with technology. This app is here to support you, not limit your fun! Talk to your parents if you have questions - they're always there to help you understand and grow. 🌟"
                    android:textColor="@color/primary_700"
                    android:textSize="16sp"
                    android:lineSpacingExtra="6dp"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:textStyle="italic" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Fun Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉 Have an awesome day!"
                android:textColor="@color/primary_600"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monarch - Your Digital Helper"
                android:textColor="@color/neutral_600"
                android:textSize="14sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>

    </LinearLayout>
</ScrollView> 