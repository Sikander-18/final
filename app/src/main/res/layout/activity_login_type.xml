<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_baby_blue"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl">

        <!-- Status bar spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_4xl" />

        <!-- App Logo/Icon -->
        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="@dimen/spacing_lg"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="@dimen/elevation_sm"
            app:cardBackgroundColor="@android:color/white">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/primary_600" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xs"
            android:fontFamily="sans-serif-medium"
            android:text="Sentinel"
            android:textColor="#111827"
            android:textSize="@dimen/text_4xl"
            android:textStyle="bold" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_4xl"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:text="The parental monitoring application"
            android:textColor="@color/primary_600"
            android:textSize="@dimen/text_base" />

        <!-- Features Card REMOVED for Minimal Design -->

        <!-- Get Started Button (Moved outside card) -->
        <Button
            android:id="@+id/btnGetStarted"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_4xl"
            android:background="@drawable/bg_button_primary"
            android:elevation="@dimen/elevation_sm"
            android:fontFamily="sans-serif-medium"
            android:text="Get Started"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_base"
            android:textStyle="bold" />

        <!-- Login Link -->
        <!-- Login Link REMOVED associated with non-form page cleanup -->

        <!-- Bottom spacing -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_xl" />

    </LinearLayout>

</ScrollView>
