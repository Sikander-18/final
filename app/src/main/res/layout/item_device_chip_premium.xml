<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:background="@drawable/bg_device_chip_selector"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp">

    <ImageView
        android:id="@+id/ivDeviceIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_device_premium"
        android:tint="@color/selector_device_item" />

    <TextView
        android:id="@+id/tvDeviceName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="sans-serif-medium"
        android:text="Device Name"
        android:textColor="@color/selector_device_item"
        android:textSize="14sp" />

    <!-- Status Dot -->
    <View
        android:id="@+id/viewStatusDot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginStart="8dp"
        android:background="#10B981"
        android:backgroundTint="#10B981" />

</LinearLayout>
