<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@android:color/white">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📷 Scan QR Code"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:gravity="center_vertical" />
            
        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Back"
            android:background="@android:color/transparent"
            android:textColor="@android:color/holo_blue_bright"
            android:paddingHorizontal="16dp" />
            
    </LinearLayout>

    <!-- Instructions -->
    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Point your camera at the QR code displayed on the parent device"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:padding="16dp"
        android:gravity="center"
        android:background="#CC000000" />

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Status Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="20dp">

        <!-- QR Code Scanning Area Indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="┌─────────────┐\n│                        │\n│     Scan Area      │\n│                        │\n└─────────────┘"
                android:textColor="@android:color/darker_gray"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:gravity="center" />
                
        </LinearLayout>

        <!-- Status Text -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 Ready to scan"
            android:textSize="16sp"
            android:textColor="@android:color/darker_gray"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Action Button -->
        <Button
            android:id="@+id/btnManualConnect"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🔗 Manual Connection"
            android:textColor="@android:color/white"
            android:background="@android:color/holo_blue_bright"
            android:textSize="16sp" />

        <!-- Help Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 Tips:
• Hold the device steady
• Ensure good lighting
• QR codes expire every 2 minutes
• Use Manual Connection if camera isn't working"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:paddingTop="16dp" />

    </LinearLayout>

</LinearLayout>